<?xml version="1.0" encoding="UTF-8"?>
<!--
  أضف هذه المحتويات داخل ملف ios/App/App/Info.plist
  ضعها داخل <dict> الرئيسي
-->
<plist>
  <dict>

    <!-- اسم التطبيق بالعربية على شاشة الآيفون -->
    <key>CFBundleDisplayName</key>
    <string>متجر أناقة CHIC</string>

    <key>CFBundleName</key>
    <string>ChicAniqa</string>

    <!-- معرف الحزمة المحدث - يجب أن يطابق Apple Developer -->
    <key>CFBundleIdentifier</key>
    <string>com.chicaniqa.store</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <!-- دعم الاتجاهات (تثبيت الواجهة بشكل طولي مريح للمستخدم) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
      <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
      <string>UIInterfaceOrientationPortraitUpsideDown</string>
      <string>UIInterfaceOrientationLandscapeLeft</string>
      <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- لون شريط الحالة الفخم المتوافق مع الهوية الجديدة -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDarkContent</string>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- السماح بشبكة HTTP السريعة (للتطوير والربط السحابي المستقر) -->
    <key>NSAppTransportSecurity</key>
    <dict>
      <key>NSAllowsArbitraryLoads</key>
      <true/>
    </dict>

    <!-- اتجاه RTL العربي للآيفون -->
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- ✨ ميزة إبداعية: إذن حفظ صور العبايات والتصاميم في الاستوديو للمشاركة ✨ -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>يتطلب متجر أناقة CHIC إذنًا لحفظ صور المنتجات والعبايات الفاخرة مباشرة في ألبوم الكاميرا الخاص بكِ لتسهيل مشاركتها.</string>

  </dict>
</plist>
