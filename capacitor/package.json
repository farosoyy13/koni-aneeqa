{
  "name": "chic-aniqa-capacitor",
  "version": "1.0.0",
  "description": "متجر أناقة CHIC - Capacitor iOS wrapper",
  "scripts": {
    "build:web": "cd ../artifacts/chic-aniqa && npm run build",
    "cap:sync": "npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios:build": "npm run build:web && npx cap sync ios && npx cap open ios",
    "ios:run": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
